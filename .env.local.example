# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DSCO (Rithum)
DSCO_API_BASE_URL=https://api.dsco.io/api/v3
DSCO_BEARER_TOKEN=your-dsco-bearer-token

# eBay
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REFRESH_TOKEN=your-ebay-refresh-token
EBAY_ENVIRONMENT=sandbox

# Shopify
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-access-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Wayfair
WAYFAIR_CLIENT_ID=your-wayfair-client-id
WAYFAIR_CLIENT_SECRET=your-wayfair-client-secret

# CommerceHub OrderStream (future)
# COMMERCEHUB_SFTP_HOST=
# COMMERCEHUB_SFTP_USER=
# COMMERCEHUB_SFTP_KEY_PATH=
